{
  "name": "markdown-to-pdf",
  "version": "1.0.0",
  "description": "将 Markdown 文档转换为美观的 PDF，支持 GitHub 风格、Mermaid 图表和 LaTeX 公式",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "md2pdf": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node dist/test.js"
  },
  "keywords": ["markdown", "pdf", "mermaid", "latex", "github"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "marked": "^9.1.6",
    "marked-highlight": "^2.0.6",
    "playwright": "^1.40.1",
    "katex": "^0.16.9",
    "highlight.js": "^11.9.0",
    "commander": "^11.1.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  }
}
